{
	"name": "admin",
	"version": "1.0.0",
	"engines": {
		"node": ">=24"
	},
	"description": "Administrative backend for EasyRead.me",
	"main": "dist/server.js",
	"scripts": {
		"start": "node --env-file .env dist/server.js",
		"dev": "concurrently --kill-others --names tsc,server --pad-prefix 'npm:dev:build' 'npm:dev:server'",
		"dev:build": "tsc --watch --preserveWatchOutput --sourceMap true",
		"dev:server": "node --env-file .env --watch-path=./dist --watch-preserve-output --inspect dist/server.js",
		"predev": "npm run build",
		"build": "npm run build:js && npm run build:css",
		"build:js": "tsc",
		"build:css": "postcss styles/main.css --output public/css/main.css",
		"lint": "eslint src/** --ext .ts",
		"format": "prettier --write 'src/**/*.ts' 'views/**/*.ejs'",
		"clean": "rimraf dist public/css"
	},
	"dependencies": {
		"@azure/data-tables": "^13.2.2",
		"@tailwindcss/postcss": "^4.2.1",
		"cors": "^2.8.5",
		"ejs": "^4.0.1",
		"express": "^5.2.1",
		"express-rate-limit": "^8.3.0",
		"helmet": "^8.1.0",
		"postcss": "^8.5.8",
		"postcss-cli": "^11.0.1",
		"tailwindcss": "^4.2.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/cors": "^2.8.17",
		"@types/ejs": "^3.1.5",
		"@types/express": "^5.0.1",
		"@types/node": "^24.11.0",
		"concurrently": "^9.2.1",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	}
}
