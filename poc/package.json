{
	"name": "api-express",
	"version": "0.1.0",
	"description": "Easy-to-read API - ExpressJS",
	"scripts": {
		"start": "npm run dev",
		"dev": "concurrently --kill-others --names tsc,server --pad-prefix 'npm:dev:build' 'npm:dev:server'",
		"dev:build": "tsc --watch --preserveWatchOutput --sourceMap true",
		"dev:server": "node --env-file .env --watch-path=./dist --watch-preserve-output --inspect dist/server.js",
		"predev": "npm run build",
		"build": "tsc",
		"preview": "node --env-file .env dist/server.js",
		"lint": "eslint src/** --ext .ts",
		"format": "prettier --write src/**/*.ts",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"@azure/data-tables": "^13.3.2",
		"@azure/monitor-opentelemetry": "^1.16.0",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"openai": "^6.24.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.1",
		"@types/node": "^22.14.0",
		"concurrently": "^9.2.1",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"jiti": "^2.6.1",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	}
}
