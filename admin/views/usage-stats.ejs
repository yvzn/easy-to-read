<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EasyRead Admin – Usage Statistics</title>
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body class="bg-gray-50 antialiased">
    <%- include('partials/sidebar') %>

    <div class="sm:ml-64 flex flex-col min-h-screen">
      <!-- Top bar -->
      <div class="h-16 bg-white border-b border-gray-200 px-6 flex items-center">
        <h1 class="text-xl font-semibold text-gray-900">Usage Statistics</h1>
      </div>

      <main class="flex-1 p-6">
        <!-- Breadcrumb -->
        <nav class="flex mb-5" aria-label="Breadcrumb">
          <ol class="inline-flex items-center gap-1 text-sm text-gray-500">
            <li><a href="/" class="hover:text-blue-700">Dashboard</a></li>
            <li class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              <span class="text-gray-800 font-medium">Usage Stats</span>
            </li>
          </ol>
        </nav>

        <!-- Doughnut overview row -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-8">
          <%
            const doughnutSections = [
              { key: 'week',  label: 'Weekly',  data: weekStats.slice(-8)  },
              { key: 'month', label: 'Monthly', data: monthStats.slice(-6) },
              { key: 'year',  label: 'Yearly',  data: yearStats.slice(-5)  },
            ];
            doughnutSections.forEach(function(section) {
              const total = section.data.reduce(function(a, b) { return a + b.count; }, 0);
          %>
          <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 flex flex-col items-center">
            <h2 class="text-sm font-semibold text-gray-700 mb-3"><%= section.label %> Overview</h2>
            <% if (total === 0) { %>
              <div class="text-gray-400 text-xs py-10">No data</div>
            <% } else { %>
              <div class="relative w-36 h-36">
                <canvas
                  data-chart="doughnut"
                  data-labels='<%- JSON.stringify(section.data.map(function(s){ return s.period; })) %>'
                  data-values="<%- JSON.stringify(section.data.map(function(s){ return s.count; })) %>"
                ></canvas>
                <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
                  <span class="text-2xl font-bold text-gray-900"><%= total %></span>
                  <span class="text-xs text-gray-500">total</span>
                </div>
              </div>
            <% } %>
            <a
              href="/usage-stats?interval=<%= section.key %>&sort=<%= sort %>"
              class="mt-4 inline-flex items-center gap-1 text-xs font-medium
                <%= interval === section.key
                  ? 'text-blue-700 font-bold underline underline-offset-2'
                  : 'text-blue-600 hover:text-blue-800 hover:underline' %>"
            >
              View by <%= section.label.toLowerCase() %>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
          <% }); %>
        </div>

        <!-- Bar chart for selected interval -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-base font-semibold text-gray-800">
              Interactions per
              <span class="text-blue-700"><%= interval %></span>
            </h2>
            <span class="text-xs text-gray-400"><%= stats.length %> period<%= stats.length !== 1 ? 's' : '' %></span>
          </div>
          <% if (stats.length === 0) { %>
            <div class="flex items-center justify-center h-48 text-gray-400 text-sm">
              No data available for the selected period.
            </div>
          <% } else { %>
            <div class="relative h-72">
              <canvas
                data-chart="bar"
                data-labels='<%- JSON.stringify(stats.map(function(s){ return s.period; })) %>'
                data-values="<%- JSON.stringify(stats.map(function(s){ return s.count; })) %>"
              ></canvas>
            </div>
          <% } %>
        </div>

        <!-- Data table -->
        <% if (stats.length > 0) { %>
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="px-5 py-4 border-b border-gray-200">
            <h3 class="text-sm font-semibold text-gray-700">Detail</h3>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
              <thead class="bg-gray-50 border-b border-gray-200 text-xs text-gray-600 uppercase tracking-wider">
                <tr>
                  <th class="px-5 py-3">
                    <a href="/usage-stats?interval=<%= interval %>&sort=<%= sort === 'asc' ? 'desc' : 'asc' %>" class="inline-flex items-center gap-1 hover:text-blue-700 transition-colors">
                      Period
                      <%- sort === 'asc' ? '↑' : '↓' %>
                    </a>
                  </th>
                  <th class="px-5 py-3 text-right">Interactions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% (sort === 'asc' ? stats : stats.slice().reverse()).forEach(function(s) { %>
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-5 py-3 font-mono text-gray-700"><%= s.period %></td>
                    <td class="px-5 py-3 text-right font-semibold text-gray-900"><%= s.count %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
        <% } %>

      </main>
      <%- include('partials/footer') %>
    </div>

    <script src="/js/chart.umd.js"></script>
    <script src="/js/admin-charts.js"></script>
  </body>
</html>
