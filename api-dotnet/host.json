{
    "version": "2.0",
    "logging": {
        "logLevel": {
            "default": "Warning",
            "Function": "Warning",
            "Host.Aggregator": "Information",
            "Host.Results": "Information"
        },
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Request;Exception"
            },
            "enableLiveMetrics": false,
            "enableDependencyTracking": true,
            "enablePerformanceCountersCollection": false
        }
    }
}
