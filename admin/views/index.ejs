<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EasyRead Admin – Dashboard</title>
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body class="bg-gray-50 antialiased">
    <%- include('partials/sidebar') %>

    <div class="sm:ml-64 flex flex-col min-h-screen">
      <div class="h-16 bg-white border-b border-gray-200 px-6 flex items-center">
        <h1 class="text-xl font-semibold text-gray-900">Dashboard</h1>
      </div>

      <main class="flex-1 p-6">
        <p class="text-sm text-gray-500 mb-6">Welcome to the EasyRead.me administration panel.</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          <a
            href="/stats"
            class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 hover:shadow-md hover:border-blue-300 transition-all group"
          >
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center justify-center w-10 h-10 bg-blue-100 rounded-lg">
                <svg class="w-5 h-5 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
              </div>
              <svg class="w-4 h-4 text-gray-400 group-hover:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </div>
            <h2 class="text-base font-semibold text-gray-900 mb-1">Usage Statistics</h2>
            <p class="text-sm text-gray-500">View usage trends over time by week, month, or year.</p>
          </a>

          <a
            href="/feedback"
            class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 hover:shadow-md hover:border-blue-300 transition-all group"
          >
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center justify-center w-10 h-10 bg-purple-100 rounded-lg">
                <svg class="w-5 h-5 text-purple-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
                </svg>
              </div>
              <svg class="w-4 h-4 text-gray-400 group-hover:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </div>
            <h2 class="text-base font-semibold text-gray-900 mb-1">Feedback</h2>
            <p class="text-sm text-gray-500">View, search, filter and delete user-submitted feedback.</p>
          </a>

          <a
            href="/maintenance"
            class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 hover:shadow-md hover:border-blue-300 transition-all group"
          >
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center justify-center w-10 h-10 bg-red-100 rounded-lg">
                <svg class="w-5 h-5 text-red-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <svg class="w-4 h-4 text-gray-400 group-hover:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </div>
            <h2 class="text-base font-semibold text-gray-900 mb-1">Maintenance</h2>
            <p class="text-sm text-gray-500">Delete old interactions and perform database cleanup.</p>
          </a>
        </div>
      </main>
      <%- include('partials/footer') %>
    </div>
  </body>
</html>
