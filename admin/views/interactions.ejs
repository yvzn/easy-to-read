<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EasyRead Admin – Interactions</title>
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body class="bg-gray-50 antialiased">
    <%- include('partials/sidebar') %>

    <div class="sm:ml-64 flex flex-col min-h-screen">
      <!-- Top bar -->
      <div class="h-16 bg-white border-b border-gray-200 px-6 flex items-center">
        <h1 class="text-xl font-semibold text-gray-900">Interactions</h1>
      </div>

      <main class="flex-1 p-6">
        <!-- Breadcrumb -->
        <nav class="flex mb-5" aria-label="Breadcrumb">
          <ol class="inline-flex items-center gap-1 text-sm text-gray-500">
            <li><a href="/" class="hover:text-blue-700">Dashboard</a></li>
            <li class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              <span class="text-gray-800 font-medium">Interactions</span>
            </li>
          </ol>
        </nav>

        <!-- Results -->
        <% if (interactions.length === 0) { %>
          <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-10 text-center">
            <svg class="mx-auto w-10 h-10 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" /></svg>
            <p class="text-sm text-gray-500">No interactions found.</p>
          </div>
        <% } else { %>
          <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="px-5 py-3 border-b border-gray-200 flex items-center justify-between">
              <span class="text-sm text-gray-600">
                <span class="font-medium text-gray-900"><%= interactions.length %></span>
                interaction<%= interactions.length !== 1 ? 's' : '' %>
              </span>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm text-left">
                <thead class="bg-gray-50 border-b border-gray-200 text-xs text-gray-600 uppercase tracking-wider">
                  <tr>
                    <th class="px-5 py-3">
                      <a
                        href="/interactions?sort=<%= sort === 'desc' ? 'asc' : 'desc' %>"
                        class="inline-flex items-center gap-1 group hover:text-blue-700 transition-colors"
                      >Date
                        <% if (sort === 'desc') { %>
                          <svg class="w-3 h-3 text-gray-400 group-hover:text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        <% } else { %>
                          <svg class="w-3 h-3 text-gray-400 group-hover:text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" /></svg>
                        <% } %>
                      </a>
                    </th>
                    <th class="px-5 py-3">Interaction ID</th>
                    <th class="px-5 py-3">Input</th>
                    <th class="px-5 py-3">Href</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  <% interactions.forEach(function(i) { %>
                    <tr
                      class="hover:bg-blue-50 transition-colors cursor-pointer"
                      onclick="window.location.href='/interactions/<%= encodeURIComponent(i.InteractionId) %>'"
                    >
                      <td class="px-5 py-3 text-gray-500 font-mono text-xs whitespace-nowrap"><%= i.formattedTimestamp %></td>
                      <td class="px-5 py-3">
                        <a
                          href="/interactions/<%= encodeURIComponent(i.InteractionId) %>"
                          class="font-mono text-xs text-blue-700 hover:underline"
                          onclick="event.stopPropagation()"
                        ><%= i.InteractionId %></a>
                      </td>
                      <td class="px-5 py-3 text-gray-700 max-w-sm">
                        <span class="line-clamp-2 text-sm"><%= i.Input %></span>
                      </td>
                      <td class="px-5 py-3 text-gray-500 max-w-xs">
                        <% if (i.Href) { %>
                          <a
                            href="<%= i.Href %>"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-xs text-blue-600 hover:underline truncate block"
                            onclick="event.stopPropagation()"
                          ><%= i.Href %></a>
                        <% } else { %>
                          <span class="text-gray-400 italic text-xs">—</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        <% } %>

      </main>
      <%- include('partials/footer') %>
    </div>
  </body>
</html>
