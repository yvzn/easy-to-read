{
  "name": "easyread-express-poc",
  "version": "1.0.0",
  "description": "Easy-to-read API - ExpressJS POC",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "concurrently --kill-others --names tsc,server --pad-prefix 'npm:dev:build' 'npm:dev:server'",
    "dev:build": "tsc --watch --preserveWatchOutput",
	"dev:server": "node --watch-path=./dist --watch-preserve-output dist/server.js",
    "build": "tsc",
    "lint": "eslint src/** --ext .ts",
    "format": "prettier --write src/**/*.ts",
	"clean": "rimraf dist"
  },
  "dependencies": {
    "@azure/data-tables": "^13.3.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "openai": "^6.24.0",
    "rimraf": "^6.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
