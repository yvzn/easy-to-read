<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EasyRead Admin – Interaction Detail</title>
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body class="bg-gray-50 antialiased">
    {{> sidebar}}

    <div class="sm:ml-64 flex flex-col min-h-screen">
      <!-- Top bar -->
      <div class="h-16 bg-white border-b border-gray-200 px-6 flex items-center">
        <h1 class="text-xl font-semibold text-gray-900">Interaction Detail</h1>
      </div>

      <main class="flex-1 p-6">
        <!-- Breadcrumb -->
        <nav class="flex mb-5" aria-label="Breadcrumb">
          <ol class="inline-flex items-center gap-1 text-sm text-gray-500">
            <li><a href="/" class="hover:text-blue-700">Dashboard</a></li>
            <li class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              <a href="/interactions" class="hover:text-blue-700">Interactions</a>
            </li>
            <li class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              <span class="text-gray-800 font-medium font-mono text-xs">{{interaction.InteractionId}}</span>
            </li>
          </ol>
        </nav>

        <!-- Detail card -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="px-5 py-3 border-b border-gray-200 bg-gray-50 flex items-center justify-between">
            <span class="text-sm font-medium text-gray-700">Interaction fields</span>
            <label class="inline-flex items-center gap-2 text-xs text-gray-500 cursor-pointer select-none">
              <input
                type="checkbox"
                id="render-linebreaks"
                checked
                class="w-3.5 h-3.5 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
              />
              Render line breaks
            </label>
          </div>

          <dl class="divide-y divide-gray-100">
            <div class="px-5 py-4 grid grid-cols-4 gap-4">
              <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide col-span-1 flex items-start pt-0.5">InteractionId</dt>
              <dd class="col-span-3 font-mono text-sm text-gray-900 break-all">{{interaction.InteractionId}}</dd>
            </div>

            <div class="px-5 py-4 grid grid-cols-4 gap-4">
              <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide col-span-1 flex items-start pt-0.5">RowKey</dt>
              <dd class="col-span-3 font-mono text-xs text-gray-500 break-all">{{interaction.rowKey}}</dd>
            </div>

            <div class="px-5 py-4 grid grid-cols-4 gap-4">
              <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide col-span-1 flex items-start pt-0.5">PartitionKey</dt>
              <dd class="col-span-3 font-mono text-xs text-gray-500 break-all">{{interaction.partitionKey}}</dd>
            </div>

            <div class="px-5 py-4 grid grid-cols-4 gap-4">
              <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide col-span-1 flex items-start pt-0.5">Timestamp</dt>
              <dd class="col-span-3 font-mono text-xs text-gray-600">{{formattedTimestamp}}</dd>
            </div>

            <div class="px-5 py-4 grid grid-cols-4 gap-4">
              <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide col-span-1 flex items-start pt-0.5">Input</dt>
              <dd id="input-display" data-raw="{{interaction.Input}}" class="col-span-3 text-sm text-gray-900 whitespace-pre-wrap">{{interaction.Input}}</dd>
            </div>

            <div class="px-5 py-4 grid grid-cols-4 gap-4">
              <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide col-span-1 flex items-start pt-0.5">Output</dt>
              <dd id="output-display" data-raw="{{interaction.Output}}" class="col-span-3 text-sm text-gray-900 whitespace-pre-wrap">{{interaction.Output}}</dd>
            </div>

            <div class="px-5 py-4 grid grid-cols-4 gap-4">
              <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide col-span-1 flex items-start pt-0.5">Href</dt>
              <dd class="col-span-3">
                {{#if interaction.Href}}
                  <a
                    href="{{interaction.Href}}"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-blue-700 hover:underline break-all"
                  >{{interaction.Href}}</a>
                {{else}}
                  <span class="text-gray-400 italic text-sm">—</span>
                {{/if}}
              </dd>
            </div>
          </dl>
        </div>

      </main>
      {{> footer}}
    </div>
    <script src="/js/interaction-detail.js"></script>
  </body>
</html>
